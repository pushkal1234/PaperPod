# Get a free API key from https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Optional: SerpAPI for Q&A "Document + Web" mode (free tier — https://serpapi.com/manage-api-key)
SERPAPI_API_KEY=your_serpapi_key_here

# Database (SQLite for demo)
DATABASE_URL=sqlite+aiosqlite:///./paperpod.db

# Audio storage
AUDIO_DIR=./audio_files

# Upload storage
UPLOAD_DIR=./uploads
